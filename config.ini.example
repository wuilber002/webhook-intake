; Documentation: README.md (English) and README.pt-BR.md (Portuguese).
; Generic webhook configuration template.
; Copy this file to config.ini and adjust values for the target environment.
[webhook]
; Address/IP where the HTTP server listens. Keep loopback unless a trusted
; firewall or reverse proxy is configured for external access.
host = 127.0.0.1
; Webhook TCP port.
port = 1604
; HTTP path that receives POST requests.
path = /webhook
; Default target for relative profile `file` values.
output_dir = ./output
; Maximum accepted request body size, in bytes.
max_body_bytes = 1048576
; When true, prints the source, selected profiles, and received body to the console.
debug = false
; Enable only when this webhook is behind a trusted reverse proxy.
; When true, uses the first IP in the X-Forwarded-For header as the source.
trust_forwarded_for = false
; Optional HTTP Basic Auth for POST requests. Keep disabled unless required.
basic_auth_enabled = false
; Username is stored here; keep the password only in the named environment variable.
basic_auth_username = webhook
basic_auth_password_env = WEBHOOK_BASIC_AUTH_PASSWORD
; Optional PBKDF2 password-hash file. When set, it has priority over the
; environment variable. Create it with --create-basic-auth-password-file.
basic_auth_password_file =
basic_auth_realm = Webhook Intake
; Do not enable outside controlled networks. Basic Auth must use HTTPS when
; the webhook listens beyond loopback; loopback is allowed for a trusted TLS proxy.
basic_auth_allow_insecure = false
; Enable direct HTTPS using the certificate and key paths below.
tls_enabled = false
; When true and both TLS files are absent, create a local self-signed certificate.
; Self-signed certificates are for development or controlled environments only.
tls_self_signed = false
; Certificate and private-key paths. Relative paths use this configuration directory.
tls_cert_file = ./tls/webhook-intake.crt
tls_key_file = ./tls/webhook-intake.key
; Subject name and validity period used only for self-signed certificate generation.
tls_self_signed_common_name = localhost
tls_self_signed_days = 365
; Valid *.conf files in this directory are loaded in alphabetical order.
profile_dir = ./profile.d
